<launch>
  <!--
    One-command car1 startup for shared-map two-car testing.

    Starts:
      - car1 base and leader controller
      - car1 LD14 lidar through raw scan republishing
      - namespaced odom TF for both robots
      - shared map_server + two AMCL nodes
      - optional map-frame follower controller
  -->
  <arg name="mode" default="teleop" />
  <arg name="ros_ip" default="192.168.137.248" />
  <arg name="lidar_port" default="/dev/ttyUSB0" />
  <arg name="base_port" default="ttyTHS1" />
  <arg name="map_file" default="$(find limo_bringup)/maps/cluster_map.yaml" />
  <arg name="start_map_follower" default="false" />

  <include file="$(find cluster_bringup)/launch/car1_no_lidar.launch">
    <arg name="mode" value="$(arg mode)" />
    <arg name="ros_ip" value="$(arg ros_ip)" />
    <arg name="base_port" value="$(arg base_port)" />
  </include>

  <include file="$(find cluster_bringup)/launch/car1_lidar.launch">
    <arg name="port_name" value="$(arg lidar_port)" />
  </include>

  <include file="$(find cluster_bringup)/launch/namespaced_tf.launch" />

  <include file="$(find cluster_bringup)/launch/multi_amcl.launch">
    <arg name="map_file" value="$(arg map_file)" />
    <arg name="robot1_scan" value="/robot1/scan" />
    <arg name="robot2_scan" value="/robot2/scan" />
  </include>

  <group if="$(arg start_map_follower)">
    <include file="$(find cluster_bringup)/launch/map_follower.launch" />
  </group>
</launch>
