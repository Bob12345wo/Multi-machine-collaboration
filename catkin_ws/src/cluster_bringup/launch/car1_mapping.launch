<launch>
  <!-- Single-car gmapping startup for creating the shared map with car1. -->
  <arg name="ros_ip" default="192.168.137.248" />
  <arg name="lidar_port" default="/dev/ttyUSB0" />
  <arg name="base_port" default="ttyTHS1" />

  <include file="$(find cluster_bringup)/launch/car1_no_lidar.launch">
    <arg name="mode" value="teleop" />
    <arg name="ros_ip" value="$(arg ros_ip)" />
    <arg name="base_port" value="$(arg base_port)" />
  </include>

  <include file="$(find cluster_bringup)/launch/ld14_lidar.launch">
    <arg name="port_name" value="$(arg lidar_port)" />
    <arg name="topic_name" value="scan" />
    <arg name="frame_id" value="base_laser" />
    <arg name="node_name" value="ldlidar_publisher_ld14" />
  </include>

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping"
        output="screen">
    <remap from="scan" to="/scan" />
    <param name="base_frame" value="base_link" />
    <param name="odom_frame" value="odom" />
    <param name="map_frame" value="map" />
    <param name="map_update_interval" value="1.0" />
    <param name="maxUrange" value="8.0" />
    <param name="maxRange" value="12.0" />
    <param name="linearUpdate" value="0.15" />
    <param name="angularUpdate" value="0.15" />
    <param name="temporalUpdate" value="1.0" />
  </node>
</launch>
